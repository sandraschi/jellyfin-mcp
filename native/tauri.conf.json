{
  "productName": "Jellyfin MCP",
  "version": "0.1.0",
  "identifier": "ai.fleet.jellyfin-mcp",
  "build": {
    "frontendDist": "../webapp/frontend/out",
    "devUrl": "http://localhost:10935",
    "beforeDevCommand": "npm --prefix ../webapp/frontend run dev"
  },
  "app": {
    "windows": [
      {
        "title": "Jellyfin MCP — Jellyfin++",
        "label": "main",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/jellyfin-mcp-backend.exe",
            "resources/.env"
    ],
    "targets": [
      "nsis"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "skip"
      },
      "nsis": {
        "installMode": "currentUser",
"installerHooks": "./windows/hooks.nsh"
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "process": {
      "all": true
    }
  }
}


