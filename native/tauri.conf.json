{
  "productName": "Jellyfin MCP",
  "version": "0.1.0",
  "identifier": "ai.fleet.jellyfin-mcp",
  "build": {
    "frontendDist": "../webapp/frontend/out",
    "devUrl": "http://localhost:10935",
    "beforeDevCommand": "npm --prefix ../webapp/frontend run dev"
  },
  "app": {
    "windows": [{
      "title": "Jellyfin MCP — Jellyfin++",
      "width": 1280,
      "height": 800,
      "minWidth": 900,
      "minHeight": 600
    }],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/jellyfin-mcp-backend"]
  },
  "plugins": {
    "shell": { "open": true },
    "fs": { "requireLiteralLeadingDot": false },
    "process": { "all": true }
  }
}
