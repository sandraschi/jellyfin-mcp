{
  "manifest_version": "0.2",
  "name": "jellyfin-mcp",
  "version": "0.1.0",
  "description": "FastMCP 3.2+ server for Jellyfin Media Server — open-source Plex alternative with plugins, WebSocket real-time events, and full OpenAPI. Includes React webapp + Tauri native wrapper.",
  "author": { "name": "sandraschi" },
  "server": {
    "type": "python",
    "entry_point": "run_server.py",
    "mcp_config": {
      "command": "uv",
      "args": ["run","--directory","${PWD}","run_server.py"],
      "env": {
        "PYTHONPATH": "${PWD}/src",
        "PYTHONUNBUFFERED": "1"
      }
    }
  },
  "tools": [
    { "name": "get_transport_config_stdio", "description": "get_transport_config(stdio)" },
    { "name": "get_transport_config_http", "description": "get_transport_config(http)" },
